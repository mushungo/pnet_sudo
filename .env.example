# Ejemplo de configuración de entorno para la conexión a la base de datos
# Copia este fichero a .env y rellena los valores correctos.
# ¡NUNCA subas el fichero .env a tu repositorio de git!

# Dirección del servidor de la base de datos
DB_SERVER=tu_servidor.database.windows.net

# Nombre de la base de datos
DB_DATABASE=nombre_de_tu_bd

# Usuario de la base de datos
DB_USERNAME=tu_usuario

# Contraseña del usuario
DB_PASSWORD=tu_contraseña

# (Opcional) El nombre del driver ODBC. '{ODBC Driver 17 for SQL Server}' es un valor común y moderno.
# Descomenta y ajusta si usas un driver diferente.
# DB_DRIVER={ODBC Driver 13 for SQL Server}
