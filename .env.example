# Ejemplo de configuración de entorno para la conexión a la base de datos
# Copia este fichero al directorio de tu proyecto y renómbralo a .env:
#
#   projects/caf/.env       para el proyecto CAF (SQL Server)
#   projects/nuevo/.env     para el proyecto nuevo (Oracle)
#
# Luego selecciona el proyecto con la variable PNET_PROJECT:
#   set PNET_PROJECT=caf      (Windows)
#   export PNET_PROJECT=caf   (Linux/Mac)
#
# Si no defines PNET_PROJECT, se usará el .env de la raíz del repo (compatibilidad).
# ¡NUNCA subas un fichero .env a git!

# ─── SQL Server ─────────────────────────────────────────────────────────────
# Motor de base de datos
DB_ENGINE=sqlserver

# Servidor SQL Server (hostname, IP o FQDN)
DB_SERVER=tu_servidor.database.windows.net

# Nombre de la base de datos
DB_DATABASE=nombre_de_tu_bd

# Credenciales
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_contraseña

# (Opcional) Driver ODBC. Por defecto: {ODBC Driver 17 for SQL Server}
# DB_DRIVER={ODBC Driver 13 for SQL Server}


# ─── Oracle ─────────────────────────────────────────────────────────────────
# Descomenta este bloque y comenta el de SQL Server si usas Oracle.
#
# DB_ENGINE=oracle
# DB_HOST=tu_servidor.oracle.com
# DB_PORT=1521
# DB_SERVICE=nombre_servicio
# DB_USERNAME=tu_usuario
# DB_PASSWORD=tu_contraseña
# DB_SCHEMA=nombre_esquema     # opcional, si es distinto del usuario
