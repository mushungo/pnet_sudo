# Configuración del proyecto nuevo — Oracle
# Copia este fichero a .env y rellena los valores reales.
# ¡NUNCA subas el fichero .env a git!

# Motor de base de datos (sqlserver | oracle)
DB_ENGINE=oracle

# Host del servidor Oracle
DB_HOST=tu_servidor.oracle.com

# Puerto (por defecto Oracle: 1521)
DB_PORT=1521

# Nombre del servicio Oracle (Service Name, no SID)
DB_SERVICE=nombre_servicio

# Credenciales
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_contraseña

# (Opcional) Esquema a usar si es distinto del usuario
# DB_SCHEMA=nombre_esquema
