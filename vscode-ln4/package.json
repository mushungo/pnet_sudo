{
  "name": "ln4-language-support",
  "displayName": "LN4 Language Support",
  "description": "Language support for PeopleNet's LN4 scripting language — syntax highlighting, diagnostics, autocomplete, hover, and go-to-definition via LSP.",
  "version": "0.1.0",
  "publisher": "pnet-sudo",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ln4"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ln4",
        "aliases": [
          "LN4",
          "ln4"
        ],
        "extensions": [
          ".ln4"
        ],
        "configuration": "./ln4.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ln4",
        "scopeName": "source.ln4",
        "path": "./syntaxes/ln4.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "LN4 Language Server",
      "properties": {
        "ln4.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter used to run the LN4 language server."
        },
        "ln4.serverArgs": {
          "type": "array",
          "default": [
            "-m",
            "ln4_lsp"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Python interpreter to start the LN4 language server."
        },
        "ln4.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the LN4 language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
