{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LN4",
  "scopeName": "source.ln4",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#dates" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-operator" },
    { "include": "#constants" },
    { "include": "#hash-refs" },
    { "include": "#at-refs" },
    { "include": "#function-calls" },
    { "include": "#identifiers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.ln4",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.ln4" }
          }
        },
        {
          "name": "comment.line.double-slash.ln4",
          "match": "//.*$"
        },
        {
          "name": "comment.line.apostrophe.ln4",
          "match": "'.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ln4",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ln4" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ln4" }
          }
        }
      ]
    },
    "dates": {
      "patterns": [
        {
          "name": "constant.other.date.ln4",
          "match": "\\{[^}\\r\\n]*\\}"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ln4",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.ln4",
          "match": "(?i)\\b(if|then|elseif|else|endif|for|to|step|next|while|wend|do|loop|until|return)\\b"
        }
      ]
    },
    "keywords-operator": {
      "patterns": [
        {
          "name": "keyword.operator.logical.ln4",
          "match": "(?i)\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.ln4",
          "match": "(?i)\\b(M4_TRUE|M4_FALSE|M4_SUCCESS|M4_ERROR|M4_WARNING|M4_NULL|M4_EMPTY|M4_AUTOLOAD_OFF|M4_AUTOLOAD_ON|M4_EQUAL|M4_NOT_EQUAL|M4_GREATER|M4_LESS|M4_GREATER_OR_EQUAL|M4_LESS_OR_EQUAL|M4_TYPE_NUMBER|M4_TYPE_FIXED_STRING|M4_TYPE_VARCHAR|M4_TYPE_LONG|M4_TYPE_DATE|M4_TYPE_TIMESTAMP|M4_TYPE_CURRENCY|M4_TYPE_VARIANT|M4_TYPE_BLOB|M4_TYPE_TIME|EQUAL|NULL|EMPTY|GREATER_OR_EQUAL|LESS_OR_EQUAL|GREATER|LESS|NOT_EQUAL)\\b"
        }
      ]
    },
    "hash-refs": {
      "patterns": [
        {
          "name": "variable.other.hash-ref.ln4",
          "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "at-refs": {
      "patterns": [
        {
          "name": "variable.other.at-ref.ln4",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function-call.ln4",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.ln4" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ln4",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ln4",
          "match": "<>|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.ln4",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.ln4",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.access.bang.ln4",
          "match": "!"
        },
        {
          "name": "keyword.operator.access.dot.ln4",
          "match": "\\.\\.?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ln4",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.ln4",
          "match": ":"
        },
        {
          "name": "punctuation.bracket.round.open.ln4",
          "match": "\\("
        },
        {
          "name": "punctuation.bracket.round.close.ln4",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.square.open.ln4",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.square.close.ln4",
          "match": "\\]"
        }
      ]
    }
  }
}
